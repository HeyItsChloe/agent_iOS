# iOS Agent Messenger - Development Dockerfile
# Supports hot reload for both frontend and backend

FROM node:20-slim

# Install Python
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy package files and install Node dependencies
COPY package*.json ./
RUN npm install

# Copy Python requirements and install
COPY python-backend/requirements.txt ./python-backend/
RUN pip3 install --break-system-packages -r python-backend/requirements.txt

# Copy all source files
COPY . .

# Environment
ENV NODE_ENV=development
ENV PYTHONUNBUFFERED=1

# Expose ports
EXPOSE 5173 8765

# Start both servers (frontend and backend)
CMD ["sh", "-c", "cd python-backend && python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8765 --reload & npm run dev -- --host 0.0.0.0"]
