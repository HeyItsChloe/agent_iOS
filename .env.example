# iOS Agent Messenger - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Backend Server Configuration
# ============================================

# Server host and port
HOST=127.0.0.1
PORT=8765

# Log level (debug, info, warning, error)
LOG_LEVEL=info

# ============================================
# OpenHands SDK Configuration (Optional)
# ============================================

# OpenHands Cloud API Key (for cloud workspaces)
# Get your key at: https://app.openhands.ai
OPENHANDS_API_KEY=

# ============================================
# LLM Configuration
# ============================================

# Default LLM model
# Supported: gpt-4, gpt-4-turbo, gpt-3.5-turbo, claude-3-opus, claude-3-sonnet, etc.
LLM_MODEL=gpt-4

# LLM API Key (OpenAI, Anthropic, etc.)
LLM_API_KEY=

# LLM Base URL (optional, for custom endpoints)
LLM_BASE_URL=

# ============================================
# Frontend Configuration
# ============================================

# Backend URL (for frontend to connect to)
VITE_BACKEND_URL=http://localhost:8765

# WebSocket URL
VITE_WEBSOCKET_URL=ws://localhost:8765

# ============================================
# Data Storage
# ============================================

# Directory for persistent data
DATA_DIR=./data

# Default workspace directory
DEFAULT_WORKSPACE=./workspace

# ============================================
# Security
# ============================================

# Enable CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:8765

# Rate limiting (requests per minute)
RATE_LIMIT=60
